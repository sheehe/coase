{
  "name": "coase",
  "private": true,
  "version": "2.0.0-alpha.1",
  "description": "Coase · Multi-Agent Research System Desktop (v2)",
  "main": "./out/main/index.js",
  "author": "Coase",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "electron-vite build",
    "preview": "node scripts/run-electron-vite.mjs preview",
    "start": "node scripts/run-electron-vite.mjs preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.107",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0"
  },
  "pnpm": {
