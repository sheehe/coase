{
  "name": "coase",
  "private": true,
  "version": "2.0.0-alpha.39",
  "description": "Coase · Multi-Agent Research System Desktop (v2)",
  "main": "./out/main/index.js",
  "author": "Coase",
  "repository": {
    "type": "git",
    "url": "https://github.com/sheehe/coase.git"
  },
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "electron-vite build",
    "fetch-pixi": "node scripts/fetch-pixi.mjs",
    "fetch-pixi:all": "node scripts/fetch-pixi.mjs --all",
    "dist:dir": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win nsis portable",
    "dist:mac": "pnpm build && electron-builder --mac dmg zip",
    "preview": "node scripts/run-electron-vite.mjs preview",
    "start": "node scripts/run-electron-vite.mjs preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.107",
    "electron-updater": "^6.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.coase.desktop",
    "productName": "Coase",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/plugins",
        "to": "plugins"
      },
      {
        "from": "resources/default-skills",
        "to": "default-skills"
      },
      {
        "from": "resources/runtime-manager/template",
        "to": "runtime-manager/template",
        "filter": [
          "pixi.toml",
          "pixi.lock"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-agent-sdk/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sheehe",
        "repo": "coase"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/runtime-manager/bin/win32-x64",
          "to": "runtime-manager/bin/win32-x64"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/runtime-manager/bin/darwin-x64",
          "to": "runtime-manager/bin/darwin-x64"
        },
        {
          "from": "resources/runtime-manager/bin/darwin-arm64",
          "to": "runtime-manager/bin/darwin-arm64"
        }
      ]
    }
  }
}
